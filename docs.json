{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Mintlify Docs",
  "colors": {
    "primary": "#1b1a1b",
    "light": "#4189f0",
    "dark": "#03123a"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Home",
        "groups": [
          {
            "group": "Introduction",
          }
        ]
      },
      {
        "tab": "Projects",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "projects/overview"
            ]
          },
          {
            "group": "Repositories",
            "pages": [
              "projects/discord-tauri",
              "projects/misskey-tauri",
              "projects/discord-oauth2",
              "projects/patches"
            ]
          }
        ]
      },
      {
        "tab": "mintlify Guides",
        "hidden": true,
        "groups": [
          {
            "group": "Introduction",
            "pages": [
              "mintlify-guides/index"
            ]
          },
          {
            "group": "Getting started",
            "pages": [
              "mintlify-guides/quickstart",
              "mintlify-guides/development"
            ]
          },
          {
            "group": "Customization",
            "pages": [
              "mintlify-guides/essentials/settings",
              "mintlify-guides/essentials/navigation"
            ]
          },
          {
            "group": "Writing content",
            "pages": [
              "mintlify-guides/essentials/markdown",
              "mintlify-guides/essentials/code",
              "mintlify-guides/essentials/images",
              "mintlify-guides/essentials/components",
              "mintlify-guides/essentials/reusable-snippets"
            ]
          },
          {
            "group": "Agent ready",
            "pages": [
              "mintlify-guides/agent-ready/prompt",
              "mintlify-guides/agent-ready/visibility",
              "mintlify-guides/agent-ready/contextual",
              "mintlify-guides/ai-tools/cursor",
              "mintlify-guides/ai-tools/claude-code",
              "mintlify-guides/ai-tools/windsurf"
            ]
          }
        ],
        "global": {
          "anchors": [
            {
              "anchor": "Documentation",
              "icon": "book-open-cover",
              "href": "https://mintlify.com/docs"
            },
            {
              "anchor": "Blog",
              "icon": "newspaper",
              "href": "https://mintlify.com/blog"
            }
          ]
        }
      },
      {
        "tab": "mintlify EXAMPLE API reference",
        "groups": [
          {
            "group": "API documentation",
            "pages": [
              "mintlify-guides/api-reference/introduction"
            ]
          },
          {
            "group": "Endpoint examples",
            "pages": [
              "mintlify-guides/api-reference/endpoint/get",
              "mintlify-guides/api-reference/endpoint/create",
              "mintlify-guides/api-reference/endpoint/delete",
              "mintlify-guides/api-reference/endpoint/webhook"
            ]
          }
        ],
        "hidden": true
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/light.svg"
  },
  "navbar": {
    "links": [],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://dashboard.mintlify.com"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/Neko7sora",
      "github": "https://github.com/Neko7sora"
    }
  },
  "background": {
    "decoration": "windows",
    "color": {
      "light": "#FEFEFE",
      "dark": "#010101"
    }
  },
  "appearance": {
    "default": "system"
  },
  "metadata": {
    "timestamp": true
  },
  "interaction": {
    "drilldown": true
  },
  "seo": {
    "indexing": "all"
  },
  "search": {
    "prompt": "a"
  },
  "styling": {
    "eyebrows": "section"
  },
  "icons": {
    "library": "lucide"
  }
}
